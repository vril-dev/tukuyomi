PUID=1000
GUID=1000
MYSQL_PORT=13306
MYSQL_DATABASE=tukuyomi
MYSQL_USER=tukuyomi
MYSQL_PASSWORD=tukuyomi
MYSQL_ROOT_PASSWORD=tukuyomi-root
MYSQL_TZ=UTC

NGX_CORAZA_UPSTREAM=server coraza:9090;
NGX_BACKEND_RESPONSE_TIMEOUT=120s
NGX_CORAZA_ADMIN_URL=/tukuyomi-admin/
NGX_CORAZA_API_BASEPATH=/tukuyomi-api/

WAF_APP_URL=http://host.docker.internal:3000
WAF_PROXY_ERROR_HTML_FILE=
WAF_PROXY_ERROR_REDIRECT_URL=
WAF_LOG_FILE=
WAF_LOG_OUTPUT_FILE=conf/log-output.json
WAF_BYPASS_FILE=conf/waf.bypass
WAF_BOT_DEFENSE_FILE=conf/bot-defense.conf
WAF_SEMANTIC_FILE=conf/semantic.conf
WAF_COUNTRY_BLOCK_FILE=conf/country-block.conf
WAF_RATE_LIMIT_FILE=conf/rate-limit.conf
WAF_IP_REPUTATION_FILE=conf/ip-reputation.conf
WAF_RULES_FILE=rules/tukuyomi.conf
WAF_CRS_ENABLE=true
WAF_CRS_SETUP_FILE=rules/crs/crs-setup.conf
WAF_CRS_RULES_DIR=rules/crs/rules
WAF_CRS_DISABLED_FILE=conf/crs-disabled.conf
WAF_FP_TUNER_MODE=mock
WAF_FP_TUNER_ENDPOINT=
WAF_FP_TUNER_API_KEY=
WAF_FP_TUNER_MODEL=
WAF_FP_TUNER_TIMEOUT_SEC=15
WAF_FP_TUNER_MOCK_RESPONSE_FILE=conf/fp-tuner-mock-response.json
WAF_FP_TUNER_REQUIRE_APPROVAL=true
WAF_FP_TUNER_APPROVAL_TTL_SEC=600
WAF_FP_TUNER_AUDIT_FILE=logs/coraza/fp-tuner-audit.ndjson
WAF_STORAGE_BACKEND=file
WAF_DB_DRIVER=sqlite
WAF_DB_ENABLED=false
WAF_DB_DSN=
WAF_DB_PATH=logs/coraza/tukuyomi.db
WAF_DB_RETENTION_DAYS=30
WAF_DB_SYNC_INTERVAL_SEC=0
WAF_STRICT_OVERRIDE=false
WAF_API_BASEPATH=/tukuyomi-api
WAF_TRUSTED_PROXY_CIDRS=
WAF_COUNTRY_HEADER_NAMES=X-Country-Code,CF-IPCountry
WAF_FORWARD_INTERNAL_RESPONSE_HEADERS=
WAF_RESPONSE_CACHE_MODE=off
WAF_RESPONSE_CACHE_MAX_ENTRIES=512
WAF_RESPONSE_CACHE_MAX_BODY_BYTES=1048576
WAF_RESPONSE_CACHE_STALE_SECONDS=30
WAF_RESPONSE_CACHE_REFRESH_TIMEOUT_SECONDS=5
WAF_RESPONSE_CACHE_REFRESH_BACKOFF_SECONDS=5
WAF_RESPONSE_CACHE_DIR=logs/coraza/response-cache
WAF_API_KEY_PRIMARY=dev-only-change-this-key-please
WAF_API_KEY_SECONDARY=
WAF_ADMIN_SESSION_SECRET=dev-only-change-this-session-secret
WAF_ADMIN_SESSION_TTL_SEC=28800
WAF_API_AUTH_DISABLE=
WAF_API_CORS_ALLOWED_ORIGINS=
WAF_ALLOW_INSECURE_DEFAULTS=

VITE_CORAZA_API_BASE=/tukuyomi-api
VITE_APP_BASE_PATH=/tukuyomi-admin
