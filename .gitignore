# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# local root env file
/.env
dist/
/bin/
runtime/

# Editor/IDE
# .idea/
# .vscode/

data/rules/*
!data/rules/empty
!data/rules/tukuyomi.conf
data/conf/*
!data/conf/
!data/conf/cache-rules.json
!data/conf/waf-bypass.json
!data/conf/waf-bypass.sample.json
!data/conf/country-block.json
!data/conf/crs-disabled.conf
!data/conf/proxy.json
!data/conf/config.json
!data/conf/sites.json
!data/conf/scheduled-tasks.json
!data/conf/rate-limit.json
!data/conf/bot-defense.json
!data/conf/semantic.json
!data/conf/notifications.json
!data/conf/ip-reputation.json
!data/conf/rules/
!data/conf/rules/README.md
!data/conf/rules/search-endpoint.conf
data/audit/*
!data/audit/.gitignore
data/cache/*
!data/cache/
!data/cache/response/
!data/cache/response/.gitignore
data/seed/*
!data/seed/.gitignore
data/logs/*
!data/logs/.gitignore
data/tmp/*
!data/tmp/.gitignore
data/scheduled-tasks/*
!data/scheduled-tasks/
!data/scheduled-tasks/README.md
data/geoip/*
!data/geoip/
!data/geoip/README.md
data/php-fpm/inventory.json
data/php-fpm/inventory.*.json
data/php-fpm/vhosts.json
data/php-fpm/vhosts.*.json
data/php-fpm/*.bak

# examples
!presets/minimal/.env
examples/*/.env
examples/nextjs/app/node_modules/
examples/api-gateway/api/node_modules/
examples/*/data/audit/*
!examples/*/data/audit/.gitignore
examples/*/data/cache/*
!examples/*/data/cache/
!examples/*/data/cache/response/
!examples/*/data/cache/response/.gitignore
examples/*/data/db/*
!examples/*/data/db/.gitignore
examples/*/data/php-fpm/*
!examples/*/data/php-fpm/.gitignore
examples/*/data/rules/crs/*
!examples/*/data/rules/crs/.gitkeep
examples/*/data/logs/*
!examples/*/data/logs/.gitignore
