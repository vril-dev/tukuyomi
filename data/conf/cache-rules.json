{
  "default": {
    "rules": [
      {
        "kind": "ALLOW",
        "match": {
          "type": "prefix",
          "value": "/_next/static/chunks/"
        },
        "methods": [
          "GET",
          "HEAD"
        ],
        "ttl": 600,
        "vary": [
          "Accept-Encoding"
        ]
      },
      {
        "kind": "ALLOW",
        "match": {
          "type": "regex",
          "value": "^/about/.*\\.html$"
        },
        "methods": [
          "GET"
        ],
        "ttl": 300,
        "vary": [
          "Accept-Encoding"
        ]
      },
      {
        "kind": "DENY",
        "match": {
          "type": "prefix",
          "value": "/tukuyomi-api/"
        },
        "methods": [
          "GET",
          "HEAD"
        ],
        "ttl": 600,
        "vary": [
          "Accept-Encoding"
        ]
      }
    ]
  },
  "hosts": {
    "admin.example.com": {
      "rules": [
        {
          "kind": "DENY",
          "match": {
            "type": "prefix",
            "value": "/"
          },
          "methods": [
            "GET",
            "HEAD"
          ],
          "ttl": 600,
          "vary": [
            "Accept-Encoding"
          ]
        },
        {
          "kind": "ALLOW",
          "match": {
            "type": "prefix",
            "value": "/path-2/"
          },
          "methods": [
            "GET",
            "HEAD"
          ],
          "ttl": 600,
          "vary": [
            "Accept-Encoding"
          ]
        }
      ]
    }
  }
}
