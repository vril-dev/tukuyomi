{
  "tasks": [
    {
      "name": "php85-test-logs",
      "enabled": true,
      "schedule": "*/1 * * * *",
      "timezone": "Asia/Tokyo",
      "command": "./data/php-fpm/binaries/php85/php -r 'date_default_timezone_set(\"Asia/Tokyo\"); file_put_contents(\"data/logs/php85-scheduled-task.log\", date(\"Y-m-d H:i:s\") . \" [php85-log-test]\\n\", FILE_APPEND);'",
      "timeout_sec": 300
    }
  ]
}
