FROM node:22-alpine AS ui-builder

WORKDIR /src/web/tukuyomi-admin

COPY web/tukuyomi-admin/package.json web/tukuyomi-admin/package-lock.json ./
RUN npm ci

COPY web/tukuyomi-admin/ ./
RUN npm run build

FROM golang:1.26.0-alpine AS builder

WORKDIR /src/coraza/src
RUN apk add --no-cache git

COPY coraza/src/go.mod coraza/src/go.sum ./
RUN go mod download

COPY coraza/src/ ./
COPY --from=ui-builder /src/web/tukuyomi-admin/dist ./internal/handler/admin_ui_dist
RUN go build -o /out/tukuyomi ./cmd/server

FROM alpine:3.19

RUN apk add --no-cache bash curl tar ca-certificates

WORKDIR /app

COPY --from=builder /out/tukuyomi /app/tukuyomi
COPY data/conf/ /app/conf/
COPY scripts/install_crs.sh /app/scripts/install_crs.sh
COPY scripts/stage_waf_rule_assets.sh /app/scripts/stage_waf_rule_assets.sh
COPY seeds/ /app/seeds/

RUN find /app/conf -type f -name '*.bak' -delete \
    && chmod +x /app/scripts/install_crs.sh /app/scripts/stage_waf_rule_assets.sh \
    && mkdir -p /app/db /app/audit /app/cache/response /app/data/tmp \
    && /app/scripts/stage_waf_rule_assets.sh /app/data/tmp/waf-import \
    && WAF_CONFIG_FILE=/app/conf/config.json /app/tukuyomi db-migrate \
    && WAF_RULE_ASSET_FS_ROOT=/app/data/tmp/waf-import WAF_CONFIG_FILE=/app/conf/config.json /app/tukuyomi db-import-waf-rule-assets \
    && UI_PREVIEW_PUBLIC_ADDR=:9090 UI_PREVIEW_ADMIN_ADDR= WAF_CONFIG_FILE=/app/conf/config.json /app/tukuyomi db-import-preview \
    && rm -rf /app/data/tmp/waf-import \
    && touch /app/conf/crs-disabled.conf

ENV WAF_CONFIG_FILE=/app/conf/config.json

EXPOSE 9090

CMD ["/app/tukuyomi"]
