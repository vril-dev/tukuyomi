WAF_CONFIG_FILE=/opt/tukuyomi/conf/config.json
WAF_PROXY_AUDIT_FILE=/opt/tukuyomi/audit/proxy-rules-audit.ndjson
WAF_SECURITY_AUDIT_FILE=/opt/tukuyomi/audit/security-audit.ndjson
WAF_SECURITY_AUDIT_BLOB_DIR=/opt/tukuyomi/audit/security-audit-blobs
WAF_SECURITY_AUDIT_ENCRYPTION_KEY=
WAF_SECURITY_AUDIT_ENCRYPTION_KEY_ID=
WAF_SECURITY_AUDIT_HMAC_KEY=
WAF_SECURITY_AUDIT_HMAC_KEY_ID=

# Required only when persistent_storage.backend=s3.
# Prefer platform secret injection or an external secret manager in production.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=
AWS_DEFAULT_REGION=
