{
  "server": {
    "listen_addr": ":9090",
    "read_timeout_sec": 30,
    "read_header_timeout_sec": 5,
    "write_timeout_sec": 0,
    "idle_timeout_sec": 120,
    "max_header_bytes": 1048576,
    "max_concurrent_requests": 0,
    "max_queued_requests": 0,
    "queued_request_timeout_ms": 0,
    "max_concurrent_proxy_requests": 0,
    "max_queued_proxy_requests": 32,
    "queued_proxy_request_timeout_ms": 100,
    "proxy_protocol": {
      "enabled": false,
      "trusted_cidrs": []
    },
    "http3": {
      "enabled": false,
      "alt_svc_max_age_sec": 86400
    },
    "tls": {
      "enabled": false,
      "cert_file": "",
      "key_file": "",
      "min_version": "tls1.2",
      "redirect_http": false,
      "http_redirect_addr": "",
      "acme": {
        "enabled": false,
        "email": "",
        "domains": [],
        "cache_dir": "/var/lib/tukuyomi/acme",
        "staging": false
      }
    }
  },
  "runtime": {
    "gomaxprocs": 0,
    "memory_limit_mb": 0
  },
  "admin": {
    "api_base_path": "/tukuyomi-api",
    "ui_base_path": "/tukuyomi-ui",
    "listen_addr": "",
    "external_mode": "api_only_external",
    "trusted_cidrs": [
      "127.0.0.1/32",
      "::1/128"
    ],
    "trust_forwarded_for": false,
    "proxy_protocol": {
      "enabled": false,
      "trusted_cidrs": []
    },
    "api_key_primary": "dev-only-change-this-key-please",
    "api_key_secondary": "",
    "api_auth_disable": false,
    "read_only": false,
    "cors_allowed_origins": [],
    "strict_override": false,
    "allow_insecure_defaults": false,
    "rate_limit": {
      "enabled": false,
      "rps": 5,
      "burst": 10,
      "status_code": 429,
      "retry_after_seconds": 1
    }
  },
  "paths": {
    "proxy_config_file": "conf/proxy.json",
    "site_config_file": "conf/sites.json",
    "php_runtime_inventory_file": "data/php-fpm/inventory.json",
    "vhost_config_file": "data/php-fpm/vhosts.json",
    "scheduled_task_config_file": "conf/scheduled-tasks.json",
    "rules_file": "rules/tukuyomi.conf",
    "override_rules_dir": "conf/rules",
    "bypass_file": "conf/waf-bypass.json",
    "country_block_file": "conf/country-block.json",
    "rate_limit_file": "conf/rate-limit.conf",
    "ip_reputation_file": "conf/ip-reputation.conf",
    "bot_defense_file": "conf/bot-defense.conf",
    "semantic_file": "conf/semantic.conf",
    "log_file": "",
    "crs_setup_file": "rules/crs/crs-setup.conf",
    "crs_rules_dir": "rules/crs/rules",
    "crs_disabled_file": "conf/crs-disabled.conf"
  },
  "proxy": {
    "rollback_history_size": 8,
    "engine": {
      "mode": "tukuyomi_proxy"
    }
  },
  "crs": {
    "enable": true
  },
  "fp_tuner": {
    "endpoint": "",
    "api_key": "",
    "model": "",
    "timeout_sec": 15,
    "require_approval": true,
    "approval_ttl_sec": 600,
    "audit_file": "audit/fp-tuner-audit.ndjson"
  },
  "storage": {
    "db_driver": "sqlite",
    "db_dsn": "",
    "db_path": "db/tukuyomi.db",
    "db_retention_days": 30,
    "db_sync_interval_sec": 0,
    "file_rotate_bytes": 8388608,
    "file_max_bytes": 268435456,
    "file_retention_days": 30
  },
  "observability": {
    "request_log": {
      "enabled": false
    },
    "tracing": {
      "enabled": false,
      "service_name": "tukuyomi",
      "otlp_endpoint": "127.0.0.1:4317",
      "insecure": true,
      "sample_ratio": 1
    }
  }
}
