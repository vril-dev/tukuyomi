{
  "upstreams": [
    {
      "name": "primary",
      "url": "http://host.docker.internal:18080",
      "weight": 1,
      "enabled": true
    }
  ],
  "load_balancing_strategy": "round_robin",
  "routes": [],
  "dial_timeout": 5,
  "response_header_timeout": 10,
  "idle_conn_timeout": 90,
  "upstream_keepalive_sec": 30,
  "max_idle_conns": 100,
  "max_idle_conns_per_host": 100,
  "max_conns_per_host": 200,
  "force_http2": true,
  "disable_compression": false,
  "expose_waf_debug_headers": false,
  "expect_continue_timeout": 1,
  "tls_insecure_skip_verify": false,
  "tls_ca_bundle": "",
  "tls_min_version": "",
  "tls_max_version": "",
  "tls_client_cert": "",
  "tls_client_key": "",
  "buffer_request_body": true,
  "max_response_buffer_bytes": 1048576,
  "flush_interval_ms": 25,
  "health_check_path": "/bench",
  "health_check_headers": {},
  "health_check_expected_body": "",
  "health_check_expected_body_regex": "",
  "health_check_interval_sec": 15,
  "health_check_timeout_sec": 2,
  "default_route": null,
  "error_html_file": "",
  "error_redirect_url": ""
}
